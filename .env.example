# Database
DATABASE_URL=postgresql://rainier:rainier_dev@localhost:5432/rainier

# QuantUnicorn
QU_USERNAME=your_email@example.com
QU_PASSWORD=your_password

# LLM API Keys (optional — Claude CLI is primary, these are fallbacks)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AI...

# Ollama (local DeepSeek)
OLLAMA_BASE_URL=http://localhost:11434

# Notifications (Apprise URLs — supports email, Slack, Telegram, etc.)
# Gmail: mailto://user:app_password@gmail.com?to=recipient@gmail.com
# Multiple: comma-separate URLs
NOTIFY_URLS=mailto://user:app_password@gmail.com?to=recipient@gmail.com

# Polygon.io (optional backup data source)
POLYGON_API_KEY=...
